# ─────────────────────────────────────────────────────────────
# Squad 8 — variáveis de ambiente (EXEMPLO)
# Copie para .env.local e preencha com as chaves REAIS.
# NUNCA comite .env / .env.local (já estão no .gitignore).
# Segredos só no servidor — jamais expor no cliente/navegador.
# ─────────────────────────────────────────────────────────────

# ── IA da Faísca: Google Gemini (ÚNICO provedor, tier gratuito) ──────────────
# Toda a IA (chat, transcrição de áudio e escrita dos briefings) roda no Gemini.
# Pegue a chave em: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
# Opcional: modelo (default gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# ── Google Agenda (OAuth) — opcional ─────────────────────────────────────────
# Crie credenciais OAuth 2.0 (tipo "Web application") no Google Cloud Console,
# habilite a "Google Calendar API" e registre o redirect abaixo. Ver docs/integracoes.md.
GOOGLE_OAUTH_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxx
# Redirect autorizado (default: <NEXT_PUBLIC_SITE_URL>/api/google/callback)
GOOGLE_OAUTH_REDIRECT=https://seu-dominio.vercel.app/api/google/callback

# Google Vertex AI (Gemini enterprise: regiões, IAM, LGPD) — alternativa ao acima
# Não é "API key": usa projeto do Google Cloud + Service Account.
GOOGLE_VERTEX_PROJECT=seu-projeto-gcp
GOOGLE_VERTEX_LOCATION=us-east1
# Caminho do JSON da Service Account (fora do repo) OU credenciais via ADC:
GOOGLE_APPLICATION_CREDENTIALS=/caminho/seguro/service-account.json

# ─────────────────────────────────────────────────────────────
# ClickUp — fonte das Crias (lista-mestre Estruturação, filtro Squad 08)
# Ver integracao/clickup/README.md e docs/modelo-de-dados.md § Integração ClickUp.
# Token SÓ server-side (cron/webhook) — jamais no cliente/navegador.
# ─────────────────────────────────────────────────────────────

# Personal API token (pk_...) ou OAuth access token
# Pegue em: ClickUp → Settings → Apps → API Token
CLICKUP_API_TOKEN=pk_xxxxxxxxxxxxxxxxxxxxxxxx

# Segredo do webhook (assinatura HMAC-SHA256 do header X-Signature)
CLICKUP_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Segredo do endpoint de sync (cron) — Authorization: Bearer <valor>
CRON_SECRET=troque-por-um-segredo-forte

# ─────────────────────────────────────────────────────────────
# Supabase — banco, auth (Google SSO) e storage
# URL e ANON são públicas (client). SERVICE_ROLE é secreta (só server).
# Pegue em: Supabase → Project Settings → API
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxx

# URL pública do app (usada no redirect do OAuth)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google OAuth do Supabase Auth (provider Google) — configurar no painel/CLI
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────
# WhatsApp · Evolution API — disparos pro grupo do cliente
# Instância própria (self-hosted ou serviço). Tudo secreto (só server).
# ─────────────────────────────────────────────────────────────
EVOLUTION_API_URL=https://sua-instancia.evolution-api.com
EVOLUTION_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
EVOLUTION_INSTANCE=squadfire
