# ─────────────────────────────────────────────────────────────
# Squad 8 — variáveis de ambiente (EXEMPLO)
# Copie para .env.local e preencha com as chaves REAIS.
# NUNCA comite .env / .env.local (já estão no .gitignore).
# Segredos só no servidor — jamais expor no cliente/navegador.
# ─────────────────────────────────────────────────────────────

# Anthropic (Claude) — API paga
# Pegue em: https://console.anthropic.com  → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Google AI Studio (Gemini via API key simples) — bom p/ começar
# Pegue em: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# Google Vertex AI (Gemini enterprise: regiões, IAM, LGPD) — alternativa ao acima
# Não é "API key": usa projeto do Google Cloud + Service Account.
GOOGLE_VERTEX_PROJECT=seu-projeto-gcp
GOOGLE_VERTEX_LOCATION=us-east1
# Caminho do JSON da Service Account (fora do repo) OU credenciais via ADC:
GOOGLE_APPLICATION_CREDENTIALS=/caminho/seguro/service-account.json
